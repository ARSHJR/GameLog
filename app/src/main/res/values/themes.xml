<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme with premium neon-dark identity -->
    <style name="Theme.GameLog" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_neon</item>
        <item name="colorPrimaryVariant">@color/bg_primary</item>
        <item name="colorOnPrimary">@color/bg_primary</item>

        <item name="colorSecondary">@color/accent_pink</item>
        <item name="colorSecondaryVariant">@color/bg_secondary</item>
        <item name="colorOnSecondary">@color/text_high_emp</item>

        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorOnSurface">@color/text_high_emp</item>
        <item name="android:colorBackground">@color/bg_primary</item>

        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="textAppearanceHeadline1">@style/AppText.Headline1</item>
        <item name="textAppearanceBody1">@style/AppText.Body1</item>

        <item name="materialButtonStyle">@style/AppButton.Primary</item>
        <item name="textInputStyle">@style/AppInput.Outlined</item>
        <item name="bottomNavigationStyle">@style/AppBottomNavigation</item>
        <item name="floatingActionButtonStyle">@style/AppFab</item>
    </style>

    <style name="AppText.Headline1" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textColor">@color/text_high_emp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="AppText.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_med_emp</item>
        <item name="fontFamily">sans-serif</item>
        <item name="android:background">@null</item>
    </style>

    <style name="AppText.ScreenTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/text_high_emp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:background">@null</item>
    </style>

    <style name="AppText.ScreenSubtitle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/text_med_emp</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">sans-serif</item>
        <item name="android:lineSpacingExtra">1dp</item>
        <item name="android:background">@null</item>
    </style>

    <style name="AppText.SectionLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/accent_neon</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.16</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:background">@null</item>
    </style>

    <style name="AppButton.ToggleSegment" parent="Widget.MaterialComponents.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/toggle_segment_text_tint</item>
        <item name="backgroundTint">@color/toggle_segment_bg_tint</item>
        <item name="strokeWidth">0dp</item>
        <item name="rippleColor">@color/accent_glow</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="AppButton.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@color/accent_neon</item>
        <item name="android:textColor">@color/text_high_emp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:elevation">8dp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="AppButton.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/accent_neon_soft</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/text_high_emp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="rippleColor">@color/accent_glow</item>
        <item name="fontFamily">sans-serif</item>
    </style>

    <style name="AppButton.PinkGhost" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/accent_pink_soft</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/accent_pink</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="rippleColor">@color/accent_pink_glow</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="AppButton.PinkSolid" parent="Widget.MaterialComponents.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@color/accent_pink</item>
        <item name="android:textColor">@color/text_high_emp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:elevation">8dp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="AppButton.ActionGlass.Base" parent="Widget.MaterialComponents.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">28dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingBottom">5dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
        <item name="iconPadding">3dp</item>
        <item name="iconSize">13dp</item>
        <item name="iconGravity">textStart</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:elevation">1.5dp</item>
    </style>

    <style name="AppButton.ActionGlass.Pin" parent="AppButton.ActionGlass.Base">
        <item name="android:background">@drawable/bg_action_pin_selector</item>
        <item name="android:textColor">@color/accent_neon</item>
        <item name="iconTint">@color/accent_neon</item>
        <item name="rippleColor">@color/accent_glow</item>
    </style>

    <style name="AppButton.ActionGlass.Complete" parent="AppButton.ActionGlass.Base">
        <item name="android:background">@drawable/bg_action_complete_selector</item>
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="iconTint">@color/accent_cyan</item>
        <item name="rippleColor">@color/accent_neon_soft</item>
    </style>

    <style name="AppButton.ActionGlass.Delete" parent="AppButton.ActionGlass.Base">
        <item name="android:background">@drawable/bg_action_delete_selector</item>
        <item name="android:textColor">@color/status_error_soft</item>
        <item name="iconTint">@color/status_error_soft</item>
        <item name="rippleColor">@color/accent_pink_glow</item>
    </style>

    <style name="AppInput.Outlined" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/accent_neon</item>
        <item name="hintTextColor">@color/accent_neon</item>
        <item name="android:textColorHint">@color/text_med_emp</item>
        <item name="boxBackgroundColor">@color/bg_secondary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <style name="AppCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">6dp</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="AppCard.Hero" parent="AppCard">
        <item name="cardBackgroundColor">@color/surface_card_soft</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="strokeColor">@color/accent_neon_soft</item>
        <item name="cardElevation">10dp</item>
    </style>

    <style name="AppCard.Glass" parent="AppCard">
        <item name="cardBackgroundColor">@color/surface_glass</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="AppCard.PinkHighlight" parent="AppCard">
        <item name="cardBackgroundColor">@color/surface_card_soft</item>
        <item name="strokeColor">@color/card_stroke_pink</item>
        <item name="cardElevation">9dp</item>
    </style>

    <style name="AppBottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView.Colored">
        <item name="android:background">@drawable/bg_bottom_nav</item>
        <item name="itemBackground">@drawable/bg_bottom_nav_item</item>
        <item name="itemIconSize">22dp</item>
        <item name="itemTextAppearanceInactive">@style/AppBottomNav.Text</item>
        <item name="itemTextAppearanceActive">@style/AppBottomNav.Text</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="AppFab" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/accent_pink</item>
        <item name="rippleColor">@color/accent_pink_glow</item>
        <item name="tint">@color/text_high_emp</item>
        <item name="elevation">10dp</item>
        <item name="pressedTranslationZ">2dp</item>
    </style>

    <style name="AppBottomNav.Text" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
</resources>