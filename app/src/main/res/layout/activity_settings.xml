<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="24dp"
    tools:context=".SettingsActivity">

    <!-- Header -->
    <ImageView
        android:id="@+id/back_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_arrow_back"
        app:tint="@color/text_med_emp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:contentDescription="Back" />

    <TextView
        android:id="@+id/settings_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SETTINGS"
        android:textColor="@color/accent_neon"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Permissions Section -->
    <TextView
        android:id="@+id/permissions_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PERMISSIONS"
        android:textColor="@color/text_disabled"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/settings_title"
        android:layout_marginTop="32dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/permissions_container"
        style="@style/AppCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/permissions_label">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/notifications_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="Notifications"
                android:textColor="@color/text_high_emp"
                android:textSize="16sp"
                app:thumbTint="@color/accent_neon"
                app:trackTint="@color/accent_glow"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/bg_primary"
                android:layout_marginHorizontal="20dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/camera_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="Camera"
                android:textColor="@color/text_high_emp"
                android:textSize="16sp"
                app:thumbTint="@color/accent_neon"
                app:trackTint="@color/accent_glow"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- App Preferences Section -->
    <TextView
        android:id="@+id/preferences_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PREFERENCES"
        android:textColor="@color/text_disabled"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/permissions_container"
        android:layout_marginTop="24dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/preferences_container"
        style="@style/AppCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/preferences_label">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/dark_mode_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text="Dark Mode"
            android:checked="true"
            android:textColor="@color/text_high_emp"
            android:textSize="16sp"
            app:thumbTint="@color/accent_neon"
            app:trackTint="@color/accent_glow"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- More Options Section -->
    <TextView
        android:id="@+id/more_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MORE"
        android:textColor="@color/text_disabled"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/preferences_container"
        android:layout_marginTop="24dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/more_container"
        style="@style/AppCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/more_label">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/security_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="Security"
                android:textColor="@color/text_high_emp"
                android:textSize="16sp"
                app:drawableEndCompat="@drawable/ic_chevron_right"
                app:drawableTint="@color/text_disabled" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/bg_primary"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/help_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="Help Center"
                android:textColor="@color/text_high_emp"
                android:textSize="16sp"
                app:drawableEndCompat="@drawable/ic_chevron_right"
                app:drawableTint="@color/text_disabled" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/bg_primary"
                android:layout_marginHorizontal="20dp"/>

            <TextView
                android:id="@+id/about_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="About GameLog"
                android:textColor="@color/text_high_emp"
                android:textSize="16sp"
                app:drawableEndCompat="@drawable/ic_chevron_right"
                app:drawableTint="@color/text_disabled" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>