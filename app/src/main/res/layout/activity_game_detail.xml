<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game_detail_screen"
    android:padding="20dp"
    tools:context=".GameDetailActivity">

    <ImageButton
        android:id="@+id/detail_back_button"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_icon_circle_grey"
        android:contentDescription="Back"
        android:padding="10dp"
        android:src="@drawable/ic_arrow_back"
        android:tint="@color/text_high_emp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/detail_screen_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Game Details"
        style="@style/AppText.ScreenTitle"
        app:layout_constraintBottom_toBottomOf="@id/detail_back_button"
        app:layout_constraintStart_toEndOf="@id/detail_back_button"
        app:layout_constraintTop_toTopOf="@id/detail_back_button" />

    <ProgressBar
        android:id="@+id/detail_loading_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/accent_neon"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/detail_back_button" />

    <TextView
        android:id="@+id/detail_loading_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Loading game details..."
        android:textColor="@color/text_med_emp"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/detail_loading_progress" />

    <LinearLayout
        android:id="@+id/detail_error_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/detail_back_button">

        <TextView
            android:id="@+id/detail_error_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unable to load game details"
            android:textColor="@color/status_error_soft"
            android:textSize="15sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/detail_retry_button"
            style="@style/AppButton.Secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:minWidth="120dp"
            android:text="Try Again" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/detail_content_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/detail_back_button">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_card_soft"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/accent_neon_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="190dp"
                        android:background="@drawable/bg_game_hero_placeholder"
                        android:foregroundGravity="center">

                        <ImageView
                            android:id="@+id/detail_hero_image"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_gravity="center"
                            android:contentDescription="Game cover placeholder"
                            android:src="@drawable/ic_games"
                            android:tint="@color/accent_cyan" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/detail_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/text_high_emp"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        tools:text="Cyberpunk 2077" />

                    <TextView
                        android:id="@+id/detail_genres"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_detail_genres"
                        android:paddingStart="12dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="8dp"
                        android:textColor="@color/accent_cyan"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Action RPG  |  Open World" />

                    <TextView
                        android:id="@+id/detail_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:lineSpacingExtra="3dp"
                        android:textColor="@color/text_soft"
                        android:textSize="14sp"
                        tools:text="A story-driven open-world RPG set in Night City." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Actions"
                        android:textColor="@color/text_high_emp"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/detail_action_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/text_med_emp"
                        android:textSize="12sp"
                        tools:text="Ready" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/detail_add_collection_button"
                        style="@style/AppButton.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Add to Collection" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/detail_favourite_button"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="14dp"
                        android:text="Favourite"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_favourite"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp"
                        app:strokeColor="@color/accent_neon_soft"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Metadata"
                        android:textColor="@color/text_high_emp"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Release date"
                        android:textColor="@color/text_med_emp"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/detail_release_date_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/text_high_emp"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="2020-12-10" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Developer"
                        android:textColor="@color/text_med_emp"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/detail_developer_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/text_high_emp"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="CD PROJEKT RED" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Publisher"
                        android:textColor="@color/text_med_emp"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/detail_publisher_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/text_high_emp"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="CD PROJEKT" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Platform"
                        android:textColor="@color/text_med_emp"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/detail_platform_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/text_high_emp"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="PC" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
