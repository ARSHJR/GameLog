<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_secondary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AppText.SectionLabel"
            android:text="Create entry" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/dialog_game_title_layout"
            style="@style/AppInput.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Game Title">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dialog_game_title_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_high_emp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/dialog_game_notes_layout"
            style="@style/AppInput.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Notes/Review">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dialog_game_notes_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:textColor="@color/text_high_emp" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialog_get_location_button"
                style="@style/AppButton.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Get Location"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/dialog_location_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Location: Not set"
                android:textColor="@color/text_med_emp"
                android:textSize="11sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialog_choose_image_button"
                style="@style/AppButton.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
                android:text="Pick Cover Image" />

        <ImageView
            android:id="@+id/dialog_image_preview"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:background="@color/surface_card" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mode"
            android:textColor="@color/text_disabled"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/dialog_mode_toggle_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@+id/btn_mode_note">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mode_note"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Note"
                android:textSize="12sp"
                app:strokeColor="@color/accent_neon" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mode_reminder"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reminder"
                android:textSize="12sp"
                app:strokeColor="@color/accent_neon" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <LinearLayout
            android:id="@+id/reminder_options_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reminder frequency"
                android:textColor="@color/text_disabled"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/reminder_frequency_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_5min"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 min"
                    app:chipBackgroundColor="@color/bg_secondary"
                    app:chipStrokeColor="@color/accent_neon"
                    android:textColor="@color/text_high_emp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_20min"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20 min"
                    app:chipBackgroundColor="@color/bg_secondary"
                    app:chipStrokeColor="@color/accent_neon"
                    android:textColor="@color/text_high_emp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_1hour"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 hour"
                    app:chipBackgroundColor="@color/bg_secondary"
                    app:chipStrokeColor="@color/accent_neon"
                    android:textColor="@color/text_high_emp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_6hour"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 hour"
                    app:chipBackgroundColor="@color/bg_secondary"
                    app:chipStrokeColor="@color/accent_neon"
                    android:textColor="@color/text_high_emp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_1day"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 day"
                    app:chipBackgroundColor="@color/bg_secondary"
                    app:chipStrokeColor="@color/accent_neon"
                    android:textColor="@color/text_high_emp" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialog_cancel_button"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:textColor="@color/text_med_emp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialog_save_button"
                style="@style/AppButton.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Save"
                android:padding="12dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>