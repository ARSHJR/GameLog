<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <gradient
                android:angle="270"
                android:startColor="#4818212E"
                android:centerColor="#3C141C28"
                android:endColor="#4A111723" />
            <stroke
                android:width="1dp"
                android:color="#6632ECFF" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="15dp">
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <gradient
                android:angle="270"
                android:startColor="#22FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
