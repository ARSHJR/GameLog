<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <gradient
                android:angle="270"
                android:startColor="#4A251722"
                android:centerColor="#3F1E121C"
                android:endColor="#4B170D17" />
            <stroke
                android:width="1dp"
                android:color="#8CFF69BD" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="15dp">
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <gradient
                android:angle="270"
                android:startColor="#1EFFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
