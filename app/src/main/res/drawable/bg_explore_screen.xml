<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/bg_primary"
                android:centerColor="#091426"
                android:endColor="#0E1C30" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="560dp"
                android:centerX="15%"
                android:centerY="8%"
                android:startColor="#292CEBFF"
                android:endColor="#001B2B42" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="620dp"
                android:centerX="100%"
                android:centerY="-5%"
                android:startColor="#2CFF69BD"
                android:endColor="#001E1530" />
        </shape>
    </item>
</layer-list>
