<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <gradient
                android:angle="270"
                android:startColor="#5F2D1A30"
                android:centerColor="#5327162A"
                android:endColor="#611E1021" />
            <stroke
                android:width="1dp"
                android:color="#A8FF69BD" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="15dp">
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <gradient
                android:angle="270"
                android:startColor="#28FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
