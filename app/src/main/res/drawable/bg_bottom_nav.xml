<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#C3111B2E"
                android:endColor="#D10D1627" />
            <corners android:radius="26dp" />
            <stroke
                android:width="1dp"
                android:color="#36577CAA" />
        </shape>
    </item>

    <item android:top="1dp" android:left="18dp" android:right="18dp">
        <shape android:shape="rectangle">
            <size android:height="2dp" />
            <gradient
                android:angle="0"
                android:startColor="#002CEBFF"
                android:centerColor="#5C2CEBFF"
                android:endColor="#00FF69BD" />
            <corners android:radius="1dp" />
        </shape>
    </item>

    <item android:left="10dp" android:top="8dp" android:right="10dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#1AFFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</layer-list>