<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <gradient
                android:angle="270"
                android:startColor="#5A203042"
                android:centerColor="#4F1B2A39"
                android:endColor="#5C16222F" />
            <stroke
                android:width="1dp"
                android:color="#8A32ECFF" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="15dp">
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <gradient
                android:angle="270"
                android:startColor="#2AFFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
